<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.application_screens.quran_fragments.SuraFragment">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/sura_name_en"
        style="@style/applicationTextStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:textColor="@color/gold"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Al-Fatiha" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/back_arrow_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:src="@drawable/back_arrow"
        app:layout_constraintBottom_toBottomOf="@id/sura_name_en"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/sura_name_en" />


    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/left_corner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:src="@drawable/left_corner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_arrow_icon" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/right_corner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:src="@drawable/right_corner"
        app:layout_constraintBottom_toBottomOf="@id/left_corner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/left_corner" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/sura_name_ar"
        style="@style/applicationTextStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gold"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@id/right_corner"
        app:layout_constraintEnd_toStartOf="@id/right_corner"
        app:layout_constraintStart_toEndOf="@id/left_corner"
        app:layout_constraintTop_toTopOf="@id/left_corner"
        tools:text="الفاتحه" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ayat_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="10dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/bottom_screen_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/right_corner"
        tools:listitem="@layout/sura_aya_item" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/bottom_screen_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bottom_screen_image"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>