<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:backgroundTint="@color/gold"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="20dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/hadeth_card_left_corner"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:src="@drawable/hadeth_card_left_corner"
                    android:layout_margin="10dp"
                    />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hadeth_card_right_corner"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:src="@drawable/hadeth_card_right_corner"
                android:layout_margin="10dp"
                />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hadeth_title"
                app:layout_constraintStart_toEndOf="@id/hadeth_card_left_corner"
                app:layout_constraintEnd_toStartOf="@id/hadeth_card_right_corner"
                app:layout_constraintTop_toTopOf="@id/hadeth_card_left_corner"
                app:layout_constraintBottom_toBottomOf="@id/hadeth_card_right_corner"
                tools:text="الحديث الأول"
                android:textStyle="bold"
                style="@style/applicationTextStyle"
                android:textSize="24sp"
                android:textColor="@color/black"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/hadeth_title"
                app:layout_constraintBottom_toTopOf="@id/hadeth_card_botttom_image"
                android:src="@drawable/hadeth_card_bg"
                android:layout_margin="16dp"
                android:scaleType="fitXY"
                />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginHorizontal="15dp"
                android:id="@+id/hadeth_content"
                app:layout_constraintTop_toBottomOf="@id/hadeth_title"
                app:layout_constraintStart_toStartOf="@id/hadeth_card_left_corner"
                app:layout_constraintEnd_toEndOf="@id/hadeth_card_right_corner"
                app:layout_constraintBottom_toTopOf="@id/hadeth_card_botttom_image"
                tools:text=" عن أمـيـر المؤمنـين أبي حـفص عمر بن\n الخطاب رضي الله عنه ، قال : سمعت رسول الله صلى الله عـليه وسلم يـقـول : ( إنـما الأعـمـال بالنيات وإنـمـا لكـل امـرئ ما نـوى \n. فمن كـانت هجرته إلى الله ورسولـه فهجرتـه إلى الله ورسـوله ومن كانت هجرته لـدنيا يصـيبها أو امرأة
                ينكحها فهجرته إلى ما هاجر إليه ).
رواه إمام المحد ثين أبـو عـبـد الله محمد بن إسماعـيل بن ابراهـيـم بن المغـيره بن بـرد زبه البخاري الجعـفي،[رقم:1] وابـو الحسـيـن مسلم بن \nالحجاج بن مـسلم القـشـيري الـنيسـابـوري [رقم :1907] رضي الله عنهما في صحيحيهما اللذين هما أصح الكتب المصنفه.
"
                style="@style/applicationTextStyle"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="16sp"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/hadeth_card_botttom_image"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:src="@drawable/hadeth_card_mosque"
                android:scaleType="fitXY"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>