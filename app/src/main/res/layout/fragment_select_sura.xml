<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.application_screens.quran_fragments.SelectSuraFragment">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/background_pic"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/main_bg"
        android:scaleType="centerCrop"
        />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/islami_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/background_pic"
        app:layout_constraintStart_toStartOf="@id/background_pic"
        app:layout_constraintEnd_toEndOf="@id/background_pic"
        android:layout_marginTop="30dp"
        android:src="@drawable/islami_logo"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/sura_list_string"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/islami_logo"
        app:layout_constraintStart_toStartOf="@id/background_pic"
        android:layout_marginStart="24dp"
        style="@style/applicationTextStyle"
        android:text="@string/suras_list"
        android:textColor="@color/white"
        android:textSize="16sp"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/suras_recycler_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/sura_list_string"
        app:layout_constraintStart_toStartOf="@id/sura_list_string"
        app:layout_constraintEnd_toEndOf="@id/background_pic"
        tools:listitem="@layout/sura_list_item"
        />
</androidx.constraintlayout.widget.ConstraintLayout>