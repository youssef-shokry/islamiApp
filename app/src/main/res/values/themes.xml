<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Islamie_app101" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorPrimary">@color/gold</item>
        <item name="colorOnPrimary">@color/gold</item>
        <item name="colorAccent">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
                <item name="colorSecondaryContainer">@color/black_transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="applicationTextStyle">
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">@font/alfont_com_janna</item>
    </style>

    <style name="bottomNavStyle">
        <item name="backgroundTint">@color/gold</item>
        <item name="itemIconTint">@drawable/bottom_nav_selected_color</item>
        <item name="itemTextColor">@drawable/bottom_nav_selected_color</item>
        <item name="itemIconSize">26dp</item>
    </style>

    <style name="active_indicator_style">
        <item name="android:color">@color/black_transparent</item>
    </style>

    <style name="roundShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="TabTextStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>